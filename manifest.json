{
   "manifest_version": 3,
   "name": "Netsuite Global Parameter Finder",
   "version": "0.1",
   "description": "Allow Netsuite Administrators to see the scripts from where the custom Company and User Preferences originated.",
   "background": {
      "service_worker": "service-worker.js"
   },
   "action": {
      "default_icon": {
         "128": "assets/broccoli_128.png",
         "16": "assets/broccoli_16.png",
         "32": "assets/broccoli_32.png"
      },
      "default_title": "NetSuite Parameter Finder"
   },
   "permissions": [ "activeTab", "sidePanel", "tabs" ],
   "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+Y",
                "mac": "Command+Shift+Y"
            },
            "description": "Toggle the NetSuite Parameter Finder side panel"
        }
   },
   "content_scripts": [
      {
         "matches": [ "https://*.netsuite.com/*" ],
         "js": [ "content-script.js" ]
      }
   ],
   "icons": {
      "128": "assets/broccoli_128.png",
      "32": "assets/broccoli_32.png",
      "16": "assets/broccoli_16.png"
   }
}
